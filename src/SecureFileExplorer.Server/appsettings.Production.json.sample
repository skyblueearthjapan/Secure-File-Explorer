{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Catalog": "Data Source=D:\\Apps\\SecureFileExplorer\\catalog.db"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5080"
      }
    }
  },
  "Catalog": {
    "Roots": [
      {
        "DisplayName": "技術部データ",
        "Path": "\\\\lineworks-sv\\Data\\技術部"
      },
      {
        "DisplayName": "電気設計",
        "Path": "D:\\MTlock関連\\技術部\\電気設計"
      }
    ],
    "ExcludeFolderNames": [ ".git", ".vs", "bin", "obj", "node_modules", "$RECYCLE.BIN", "System Volume Information" ],
    "ExcludeExtensions": [ ".tmp", ".lnk" ]
  },
  "IpRestriction": {
    "Enabled": true,
    "AllowedCidrs": [ "127.0.0.1/32", "::1/128", "192.168.1.0/24" ]
  },
  "ExcelLog": {
    "Enabled": true,
    "FilePath": "D:\\MTlock関連\\system\\アクセスログ\\access-log.xlsx",
    "FlushIntervalSeconds": 60
  },
  "Smtp": {
    "Enabled": true,
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UseStartTls": true,
    "User": "imaizumi@lineworks-local.info",
    "Password": "<<GoogleアプリパスワードをMTSV上で設定（gitに入れない）>>",
    "FromAddress": "imaizumi@lineworks-local.info",
    "FromName": "Secure File Explorer 監視",
    "PollSeconds": 30
  },
  "Alert": {
    "Enabled": true,
    "WindowMinutes": 30,
    "CooldownMinutes": 30,
    "CheckIntervalSeconds": 60,
    "MaxDetailRows": 50,
    "Recipients": [
      "imaizumi@lineworks.co.jp",
      "tsujino@lineworks.co.jp",
      "c-matusita@lineworks.co.jp",
      "t-ichida@lineworks.co.jp"
    ],
    "Levels": [
      { "Name": "注意",     "Threshold": 10 },
      { "Name": "警告",     "Threshold": 30 },
      { "Name": "異常警告", "Threshold": 50 }
    ]
  }
}
