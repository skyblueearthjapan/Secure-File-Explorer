<Application x:Class="SecureFileExplorer.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SecureFileExplorer.Client.Converters"
             xmlns:local="clr-namespace:SecureFileExplorer.Client">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:KindToBrushConverter x:Key="KindToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
