<Window x:Class="SecureFileExplorer.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SecureFileExplorer.Client"
        Title="Secure File Explorer - 技術部ファイルビューアー" Height="660" Width="1040"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisLocal"/>

        <!-- 検索ボックス（角丸） -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ツールバーボタン（検索/更新/ログ/上へ） -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Foreground" Value="#FF3A3B3F"/>
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FFF0F4FA"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- パンくずのリンク風ボタン -->
        <Style x:Key="CrumbButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource CrumbText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GridView 列見出し（淡い青） -->
        <Style x:Key="ColHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background"  Value="{StaticResource ColumnHeaderBg}"/>
            <Setter Property="Foreground"  Value="{StaticResource ColumnHeaderText}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"     Value="13,0,0,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColumnHeaderLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- 一覧の行（選択=薄青＋左3pxアクセント / ホバー=薄青）。複数選択は使わない。 -->
        <Style x:Key="FileRowStyle" TargetType="ListViewItem">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource InkText}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="3,0,0,0">
                            <GridViewRowPresenter VerticalAlignment="Center" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{StaticResource SelectionBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- 1. タイトルバー -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBg}" BorderBrush="{StaticResource TitleBarLine}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Border Width="15" Height="15" CornerRadius="3" Margin="0,0,8,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2F8A55" Offset="0"/>
                            <GradientStop Color="#FF1D6647" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Text="Secure File Explorer ── 技術部ファイルビューアー"
                           FontSize="12.5" Foreground="#FF3A3B3F" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 2. 検索ツールバー -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource ToolbarLine}" BorderThickness="0,0,0,1">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="ファイル名で検索…" Foreground="#FF9A9B9F" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13.5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Grid.Column="1" Content="検索" Style="{StaticResource ToolbarButton}"
                        Margin="9,0,0,0" Command="{Binding SearchCommand}"/>
                <Button Grid.Column="2" Content="更新" Style="{StaticResource ToolbarButton}"
                        Margin="9,0,0,0" Command="{Binding RefreshCommand}"/>
                <Button Grid.Column="3" Content="ログ" Style="{StaticResource ToolbarButton}"
                        Margin="9,0,0,0" Click="OpenLog_Click"/>
            </Grid>
        </Border>

        <!-- 3. パンくず -->
        <Border Grid.Row="2" Background="{StaticResource CrumbBg}" BorderBrush="{StaticResource CrumbLine}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,9">
                <Button Content="↑ 上へ" Style="{StaticResource ToolbarButton}" Height="27" Padding="10,0"
                        Margin="0,0,12,0" Command="{Binding NavigateUpCommand}"/>
                <ItemsControl ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource CrumbButton}" Content="{Binding Name}"
                                        Command="{Binding DataContext.NavigateBreadcrumbCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <TextBlock Text="  &#x203A;  " Foreground="{StaticResource CrumbSep}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 4. 本体: 左ツリー / 右一覧 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="266" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左ペイン -->
            <DockPanel Grid.Column="0" Background="White">
                <Border DockPanel.Dock="Top" Background="{StaticResource AccentBrush}" Height="30">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8B7;"
                                   Foreground="White" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="フォルダー" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Border>
                <TreeView x:Name="FolderTree" BorderThickness="0" Background="{StaticResource TreeBg}"
                          ItemsSource="{Binding RootFolders}"
                          SelectedItemChanged="FolderTree_SelectedItemChanged">
                    <TreeView.Resources>
                        <!-- 選択色を淡青に上書き（テンプレート差し替えなしで実現） -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFEAF3FC"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF1F4F86"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFEAF3FC"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF1F4F86"/>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="2,3"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8B7;"
                                           Foreground="{StaticResource Type.Folder}" FontSize="15"
                                           Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontSize="13.5" Foreground="#FF2C2D31"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource PaneLine}"/>

            <!-- 右ペイン: フォルダー＋ファイル一覧 -->
            <ListView x:Name="FileList" Grid.Column="2" BorderThickness="0"
                      ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      ItemContainerStyle="{StaticResource FileRowStyle}"
                      SelectionMode="Single" AllowDrop="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="FileList_MouseDoubleClick"
                      PreviewKeyDown="FileList_PreviewKeyDown"
                      PreviewMouseMove="FileList_PreviewMouseMove">
                <ListView.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding OpenEntryCommand}"/>
                </ListView.InputBindings>
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource ColHeaderStyle}">
                        <!-- アイコン（種別で4形・種別色） -->
                        <GridViewColumn Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE8A5;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Folder">
                                                        <Setter Property="Text" Value="&#xE8B7;"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Image">
                                                        <Setter Property="Text" Value="&#xEB9F;"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Zip">
                                                        <Setter Property="Text" Value="&#xF12B;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- 名前（黒固定） -->
                        <GridViewColumn Header="名前" Width="360">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13.5"
                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource InkText}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- 種類（種別色） -->
                        <GridViewColumn Header="種類" Width="92">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TypeLabel}" VerticalAlignment="Center" FontSize="13.5"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- サイズ（グレー） -->
                        <GridViewColumn Header="サイズ" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeLabel}" VerticalAlignment="Center" FontSize="13.5"
                                               Foreground="{StaticResource MetaText}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- 更新日時（グレー） -->
                        <GridViewColumn Header="更新日時" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ModifiedLabel}" VerticalAlignment="Center" FontSize="13.5"
                                               Foreground="{StaticResource MetaText}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- 5. ステータスバー -->
        <Border Grid.Row="4" Background="{StaticResource StatusBg}" BorderBrush="{StaticResource PaneLine}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource CrumbText}"/>
                    <TextBlock Text="　|　" FontSize="12" Foreground="{StaticResource CrumbSep}"/>
                    <TextBlock Text="{Binding CurrentUserLabel}" FontSize="12" Foreground="{StaticResource CrumbText}"/>
                </StackPanel>
                <ProgressBar Width="120" Height="10" HorizontalAlignment="Right" IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisLocal}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
