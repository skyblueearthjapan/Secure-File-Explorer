<Window x:Class="SecureFileExplorer.Client.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アクセスログ" Height="520" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="再読み込み" Padding="12,4" Click="Reload_Click"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#555"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="LogList" ItemsSource="{Binding Rows}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="日時" Width="150" DisplayMemberBinding="{Binding Time}"/>
                    <GridViewColumn Header="ユーザー" Width="160" DisplayMemberBinding="{Binding UserName}"/>
                    <GridViewColumn Header="操作" Width="110" DisplayMemberBinding="{Binding Action}"/>
                    <GridViewColumn Header="対象" Width="200" DisplayMemberBinding="{Binding Target}"/>
                    <GridViewColumn Header="成否" Width="50" DisplayMemberBinding="{Binding Result}"/>
                    <GridViewColumn Header="PC名" Width="100" DisplayMemberBinding="{Binding MachineName}"/>
                    <GridViewColumn Header="IP" Width="110" DisplayMemberBinding="{Binding IpAddress}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="2" Margin="0,6,0,0" Foreground="#888"
                   Text="※ 新しい順・最新200件。実ファイルパスは記録・表示されません。"/>
    </Grid>
</Window>
